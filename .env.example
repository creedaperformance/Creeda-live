# CREEDA environment reference
#
# Copy this file to .env.local for local web development. Keep .env.local,
# .env.production, and all real secret-bearing env files untracked.

# Public, client-exposed values. These are safe to store as GitHub Actions vars
# and hosting provider public/build env vars.
NEXT_PUBLIC_SITE_URL=https://www.creeda.in
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional public integrations. Leave blank to disable or use app defaults.
NEXT_PUBLIC_GA_MEASUREMENT_ID=
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Server-only secrets. Store these as secrets in GitHub/hosting, never in
# NEXT_PUBLIC_* variables and never in client code.
SUPABASE_SERVICE_ROLE_KEY=
DATABASE_URL=
INDEXNOW_KEY=
INDEXNOW_API_TOKEN=

# Optional local diagnostics only. Do not use personal or production user
# passwords here; prefer disposable test accounts.
DIAG_TEST_EMAIL=
DIAG_TEST_PASSWORD=

# Expo/mobile public values. Expo exposes EXPO_PUBLIC_* values to the mobile app.
# The mobile app can also read the web public Supabase values through app.config.js.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=
EXPO_PUBLIC_API_BASE_URL=http://localhost:3000
